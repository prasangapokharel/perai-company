SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=your_supabase_anon_or_publishable_key
SUPABASE_PASSWORD=your_supabase_db_password

# Primary: Supabase connection pooler
DB_HOST=aws-1-ap-south-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.YOUR_PROJECT_REF
DB_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# Fallback: direct database host
DB_HOST_FALLBACK=db.YOUR_PROJECT_REF.supabase.co
DB_USER_DIRECT=postgres
DB_URL_FALLBACK=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

JWT_SECRET=change-this-to-a-long-random-string

GROQ_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=your_groq_api_key

RAG_TOP_K=3
RAG_MAX_CONTEXT_CHARS=1200
RAG_RECORD_MAX_CHARS=360
CHAT_COMPLETION_CAP=400
DEFAULT_MAX_TOKENS=350
